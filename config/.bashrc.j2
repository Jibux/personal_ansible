# Generated by ansible

GIT_REPOSITORIES_PATH={{ git_repositories_path }}

if ! shopt -oq posix; then
	COMPLETE_ALIAS="$GIT_REPOSITORIES_PATH/bash/complete-alias/complete_alias"
	# To make ls work with fzf
	COMPAL_AUTO_UNMASK=1
	if [ -f "$COMPLETE_ALIAS" ]; then
		. "$COMPLETE_ALIAS"
		# auto complete all aliases
		complete -F _complete_alias "${!BASH_ALIASES[@]}"
	fi
fi

PATH=$PATH:$GIT_REPOSITORIES_PATH/git/diff-so-fancy

[ -f "$GIT_REPOSITORIES_PATH/bash/kube-ps1/kube-ps1.sh" ] && source "$GIT_REPOSITORIES_PATH/bash/kube-ps1/kube-ps1.sh"

# PYTHON SCRIPTS
{% for item in python_scripts + specific_python_scripts|d([]) %}
alias {{ item|basename }}='uv run {{ project_root_path }}/{{ item }}'
{% endfor %}

