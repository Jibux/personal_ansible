# Generated by ansible
{% if git_work_settings is defined %}
[user]
	email = {{ git_work_settings.email }}
	name = {{ git_work_settings.user }}

[includeIf "gitdir:{{ git_work_settings.personnal_dir | regex_replace('/*$', '/') }}"]
	path = ~/.gitconfig-perso
{% else %}
[include]
	path = ~/.gitconfig-perso
{% endif %}
