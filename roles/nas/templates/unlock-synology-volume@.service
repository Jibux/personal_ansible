[Unit]
Description=Unlock %i synology volume

[Service]
Type=oneshot
ExecStart={{ unlock_synology_volume_python }} {{ unlock_synology_volume_script }} --credentials {{ nas_admin_credentials_path }} --volume-passwords-file {{ nas_volume_passwords_path }} --volumes %i {{ "--no-verify" if nas_ssl_no_verify }}

[Install]
WantedBy=multi-user.target
